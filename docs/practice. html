<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Pluck Practice</title>

<style>
/* =========================================================
CHANGE 2026-05-02 12:02:00 EST
UI STRUCTURE FOR TABLE LAYOUT
========================================================= */

body {
  margin: 0;
  font-family: Georgia;
  background: #07110b;
  color: white;
}

.player {
  position: absolute;
  width: 260px;
  padding: 10px;
  border: 1px solid gold;
  border-radius: 10px;
  text-align: center;
}

.ai-left { top: 150px; left: 20px; }
.ai-right { top: 150px; right: 20px; }
.human { bottom: 20px; left: 50%; transform: translateX(-50%); width: 400px; }

.card {
  display: inline-block;
  width: 40px;
  height: 55px;
  border: 1px solid black;
  margin: 2px;
  text-align: center;
  line-height: 55px;
  background: white;
  color: black;
  cursor: pointer;
}

.card.red { color: red; }
.card.back { background: black; color: gold; }

.trick-area {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  border: 1px dashed gold;
  padding: 10px;
}
</style>
</head>

<body>

<div id="player1" class="player ai-left"></div>
<div id="player2" class="player ai-right"></div>
<div id="player0" class="player human"></div>

<div class="trick-area" id="played"></div>

<select id="modeSelect">
  <option value="CLASSIC">Pluck Classic 7-6-4</option>
  <option value="HIGH_STAKES">High Stakes Pluck 9-5-3</option>
</select>

<button onclick="deal()">Deal</button>
<button onclick="rotate()">Rotate Dealer</button>

<script>

/* =========================================================
CHANGE 2026-05-02 11:42:00 EST
QUOTA MODE SYSTEM
========================================================= */

const QUOTA_MODES = {
  CLASSIC: [7,6,4],
  HIGH_STAKES: [9,5,3]
};

let mode = "CLASSIC";
let dealer = 0;
let hands = [[],[],[]];

/* =========================================================
CHANGE 2026-05-02 12:10:00 EST
DECK FIX FOR PLUCK RULES
========================================================= */

function deck() {
  const suits = ["♣","♦","♥","♠"];
  const ranks = ["A","K","Q","J","10","9","8","7","6","5","4","3","2"];
  let d = [];

  for (let s of suits) {
    for (let r of ranks) {
      let c = r+s;
      if (c==="2♦"||c==="2♥"||c==="2♠") continue;
      d.push({r,s,label:c});
    }
  }

  d.push({r:"BJ",s:"J"});
  d.push({r:"LJ",s:"J"});
  return d;
}

/* =========================================================
CHANGE 2026-05-02 11:55:00 EST
SEAT + QUOTA MAPPING
========================================================= */

function seatInfo(i){
  let q = QUOTA_MODES[mode];

  if(i===dealer) return {seat:"Dealer",quota:q[0]};
  if(i===(dealer+1)%3) return {seat:"Left",quota:q[1]};
  return {seat:"Right",quota:q[2]};
}

/* =========================================================
CHANGE 2026-05-02 12:18:00 EST
CARD PLAY INTERACTION
========================================================= */

function play(i,card){
  if(i!==0) return;

  let idx = hands[i].findIndex(c=>c.label===card.label);
  if(idx<0) return;

  let [p] = hands[i].splice(idx,1);

  let el=document.createElement("div");
  el.className="card";
  el.textContent=p.label;
  document.getElementById("played").appendChild(el);

  render();
}

/* =========================================================
CORE DEAL LOGIC
========================================================= */

function deal(){
  let d = deck().sort(()=>Math.random()-0.5);
  hands=[[],[],[]];

  d.forEach((c,i)=>hands[i%3].push(c));
  render();
}

function rotate(){
  dealer=(dealer+1)%3;
  render();
}

function render(){
  for(let i=0;i<3;i++){
    let div=document.getElementById("player"+i);
    let s=seatInfo(i);

    div.innerHTML=`<b>Player ${i}</b><br>${s.seat}<br>Quota ${s.quota}<br>`;

    hands[i].forEach(c=>{
      let el=document.createElement("div");
      el.className="card";
      el.textContent=c.label;
      el.onclick=()=>play(i,c);
      div.appendChild(el);
    });
  }
}

document.getElementById("modeSelect").onchange=(e)=>{
  mode=e.target.value;
  render();
};

render();

</script>

</body>
</html>
